*.lnk

# Project-specific files
# Keep debug logs for development but exclude from git
debug_logs/*.log
debug_logs/*.json
debug_logs/*.txt

# Keep monitoring logs for development but exclude from git
monitoring_logs/*.json

# Exclude coverage reports (can be regenerated)
htmlcov/

# Exclude pytest cache
.pytest_cache/

# Exclude benchmark results
.benchmarks/

# Exclude workflow status (runtime generated)
.workflow_status/

# Keep test data files (these are important for testing)
# test_input_data_files/ - DO NOT IGNORE

# Keep important documentation and implementation files
# All .md files should be tracked
# All .py files should be tracked
# plans/ directory should be tracked

# Temporary files
*.tmp
*.temp
*~

# IDE files
.vscode/
.idea/
*.swp
*.swo

